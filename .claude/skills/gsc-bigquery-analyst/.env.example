# gsc-bigquery-analyst skill の環境変数テンプレート
# このファイルを参考に、リポジトリ直下の .env.local に同じキーを設定する。
# （.env.local と .secrets/*.json は .gitignore して絶対に commit しないこと）

# サービスアカウント鍵(JSON)のパス。GSC API と BigQuery の両方をこの1つで認証する。
GOOGLE_APPLICATION_CREDENTIALS=.secrets/itwords-analytics-sa.json

# Search Console のプロパティ。
#   URLプレフィックス型: https://itwords.jp/
#   ドメイン型:          sc-domain:itwords.jp
GSC_SITE_URL=https://itwords.jp/

# BigQuery を実行する GCP プロジェクトID
GCP_PROJECT_ID=itwords-analytics

# GA4 → BigQuery エクスポート先のデータセット名（GA4プロパティ数値ID）
# 例: analytics_123456789  ※ node scripts/bq.mjs --list-datasets で確認できる
GA4_DATASET=analytics_000000000
